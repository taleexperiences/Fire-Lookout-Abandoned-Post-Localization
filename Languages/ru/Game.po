msgid "<Kailyn>Kailyn: </><Speech>Yeah, you too!</>"
msgstr "<Kailyn>Кейлин: </><Speech>Да, тебе тоже!</>"

#. Key:	9EE7F1224672ABA11446F5A24C75086D
msgctxt ",9EE7F1224672ABA11446F5A24C75086D"
msgid "<Sam>Sam: </><Speech>Uh… maybe halfway. Hard to tell out here.</>"
msgstr "<Sam>Сэм: </><Speech>Эм… может, на полпути. Тут сложно понять.</>"

#. Key:	33EBC4744146E1C6694439BDE4A2D538
