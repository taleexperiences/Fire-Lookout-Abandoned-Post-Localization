msgctxt ",4D61CC774558CC5193906DACC9684B09"
msgid "<Kailyn>Kailyn: </><Speech>Still, beats talking with Rick all night.</>"
msgstr "<Kailyn>Кейлин: </><Speech>И всё равно лучше, чем всю ночь говорить с Риком.</>"

#. Key:	05C83FE5444EBC3A6E7354842C2D401F
msgctxt ",05C83FE5444EBC3A6E7354842C2D401F"
msgid "<Sam>Sam: </><Speech>No… you didn’t.</>"
msgstr "<Sam>Сэм: </><Speech>Нет… не зря.</>"

