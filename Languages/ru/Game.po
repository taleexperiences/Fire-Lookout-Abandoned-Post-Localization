msgid "<Kailyn>Kailyn: </><Speech>Uh-huh, it's connected to it's own frequency.</>"
msgstr "<Kailyn>Кейлин: </><Speech>Ага, оно подключено к собственной частоте.</>"

#. Key:	249B47D3425881283AEBB9AF54A0873B
msgctxt ",249B47D3425881283AEBB9AF54A0873B"
msgid "<Sam>Sam: </><Speech>Wait... how did you even get the radio to my supply box?</>"
msgstr "<Sam>Сэм: </><Speech>Стой... как ты вообще доставила радио в мой ящик с припасами?</>"

#. Key:	77663CBC4189906DE36E92A6BBFD0370
msgctxt ",77663CBC4189906DE36E92A6BBFD0370"
msgid "<Speech>Wait...</>"
msgstr "<Speech>Стой...</>"

#. Key:	AD879F2948A6488FF39FEEBD974E3D75
msgctxt ",AD879F2948A6488FF39FEEBD974E3D75"
msgid "<Kailyn>Kailyn: </><Speech>Exactly! That's why I got you got that radio so we can continue to talk.</>"
msgstr "<Kailyn>Кейлин: </><Speech>Именно! Поэтому я и достала тебе это радио, чтобы мы могли продолжать говорить.</>"

#. Key:	014C5F6C43E33CBD19F312B6266583F2
msgctxt ",014C5F6C43E33CBD19F312B6266583F2"
msgid "<Sam>Sam: </><Speech>Ah I see... Well...it's good to hear from you again</>"
msgstr "<Sam>Сэм: </><Speech>А, понятно... Ну... рад снова тебя слышать</>"

#. Key:	EE77473241729678430189B1C1554B8F
msgctxt ",EE77473241729678430189B1C1554B8F"
msgid "<Speech>It's good to hear from you again</>"
msgstr "<Speech>Рад снова тебя слышать</>"

