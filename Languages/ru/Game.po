msgid "<Rick>Rick: </><Speech>Hey! I know you're there, come answer the radio!</>"
msgstr "<Rick>Рик: </><Speech>Эй! Я знаю, что ты там, ответь по радио!</>"

#. Key:	189409FE4BA802DE9KailynF39B426BBAFEA
