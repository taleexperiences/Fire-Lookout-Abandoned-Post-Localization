msgid "<Sam>Sam: </><Speech>Hey, I'm back again. I found the first aid kit.</>"
msgstr "<Sam>Сэм: </><Speech>Эй, я снова вернулся. Я нашёл аптечку.</>"

#. Key:	BFA1794D4E3D51DF017E0ABC4556B171
msgctxt ",BFA1794D4E3D51DF017E0ABC4556B171"
