msgid "<Kailyn>Kailyn: </><Speech>Soooo… how far are you?</>"
msgstr "<Kailyn>Кейлин: </><Speech>Ну тааак… как далеко ты уже?</>"

#. Key:	63551AA243DDF6430C0221AF7FA82211
msgctxt ",63551AA243DDF6430C0221AF7FA82211"
msgid "<Sam>Sam: </><Speech>A little. Mostly just ready to sit down. You’d probably hate the walk.</>"
msgstr "<Sam>Сэм: </><Speech>Немного. В основном просто хочу уже сесть. Тебе бы эта прогулка, наверное, не понравилась.</>"

#. Key:	93CBF7824E2668B63CCB49854FF590CE
msgctxt ",93CBF7824E2668B63CCB49854FF590CE"
msgid "<Speech>A little.</>"
msgstr "<Speech>Немного.</>"

