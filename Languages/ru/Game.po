msgctxt ",A23FKailynD04001621F62A99DBAB5D741D5"
msgid "<Rick>Rick: </><Speech>Actually, Clearwater, get back on the radio.</>"
msgstr "<Rick>Рик: </><Speech>Вообще-то, Clearwater, вернись на радио.</>"

#. Key:	2Kailyn38C6C4725EA3E5990DDA53D6068B2
msgctxt ",2Kailyn38C6C4725EA3E5990DDA53D6068B2"
