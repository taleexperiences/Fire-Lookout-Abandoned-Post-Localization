msgctxt ",36377BF6420441A35B8FB1BBAB4E022E"
msgid "<Sam>Sam: </><Speech>You saying it's only us two on this line?</>"
msgstr "<Sam>Сэм: </><Speech>Ты хочешь сказать, что на этой линии только мы двое?</>"

