#. Key:	CEF7F4C74CBF38933E07D49933DBDCD4
msgctxt ",CEF7F4C74CBF38933E07D49933DBDCD4"
msgid "<Kailyn>Kailyn: </><Speech>Good. Then I didn’t waste my favor getting that radio to you.</>"
msgstr "<Kailyn>Кейлин: </><Speech>Хорошо. Значит, я не зря потратила свою услугу, чтобы доставить тебе это радио.</>"

#. Key:	EBAF2E744C4D454AE260FEB9B25E97AE
msgctxt ",EBAF2E744C4D454AE260FEB9B25E97AE"
msgid "<Sam>Sam: </><Speech>Okay, I got it.</>"
msgstr "<Sam>Сэм: </><Speech>Ладно, понял.</>"

#. Key:	DFF2F88243003C88DF94AB8C555BEC7F
msgctxt ",DFF2F88243003C88DF94AB8C555BEC7F"
msgid "<Speech>Okay</>"
msgstr "<Speech>Ладно</>"

#. Key:	64F945274DB4714CC09750BE51EDA98A
msgctxt ",64F945274DB4714CC09750BE51EDA98A"
msgid "<Rick>Rick: </><Speech>Good! Okay...listen. I need you to take a look at the map to your left. You should see a shed marked out by the lake. You're gonna need to take a hike down there and pickup your supplies.</>"
msgstr "<Rick>Рик: </><Speech>Хорошо! Ладно... слушай. Мне нужно, чтобы ты посмотрел на карту слева от себя. Там должен быть отмечен сарай у озера. Тебе придётся сходить туда и забрать припасы.</>"

#. Key:	D36D2E024B36554ECBA8BF96BA3E3A3A
msgctxt ",D36D2E024B36554ECBA8BF96BA3E3A3A"
msgid "<Sam>Sam: </><Speech>You got it.</>"
msgstr "<Sam>Сэм: </><Speech>Понял.</>"

#. Key:	E8DF41D2435E691DC48E88ACB7FF01BD
msgctxt ",E8DF41D2435E691DC48E88ACB7FF01BD"
msgid "<Speech>You got it</>"
msgstr "<Speech>Понял</>"

#. Key:	31E466934D3CC173EE3519B494F97EEF
msgctxt ",31E466934D3CC173EE3519B494F97EEF"
msgid "<Kailyn>Kailyn: </><Speech>Alright, I’ll let you get back to walking. Don’t want you ending up lost while talking to me. Call me when you’re back at your tower, okay?</>"
msgstr "<Kailyn>Кейлин: </><Speech>Ладно, не буду отвлекать тебя от дороги. Не хочу, чтобы ты заблудился, пока разговариваешь со мной. Позвони, когда вернёшься к своей вышке, хорошо?</>"

#. Key:	B76E0F8A4EEFAD7E7AB270A8D8166857
msgctxt ",B76E0F8A4EEFAD7E7AB270A8D8166857"
msgid "<Kailyn>Kailyn: </><Speech>Sweet. See you then.</>"
msgstr "<Kailyn>Кейлин: </><Speech>Отлично. Увидимся тогда.</>"

#. Key:	C7EAA9174650258D9CE3268D35F538C2
msgctxt ",C7EAA9174650258D9CE3268D35F538C2"
msgid "<Sam>Sam: </><Speech>Hello, Clearwater here. Just wanted to confirm I’ve picked up the supplies, Rick.</>"
msgstr "<Sam>Сэм: </><Speech>Алло, это Clearwater. Просто хотел подтвердить, что забрал припасы, Рик.</>"

#. Key:	50A6B3094CDD9E8B03D6A6A785421CDC
msgctxt ",50A6B3094CDD9E8B03D6A6A785421CDC"
msgid "<Speech>Hello, Clearwater here</>"
msgstr "<Speech>Алло, это Clearwater</>"

