msgctxt ",667F561549EE0A696F0A02A4571EBB6E"
msgid "<Sam>Sam: </><Speech>I guess so, but I think I am pretty stocked up. I'll let you know if I need anything.</>"
msgstr "<Sam>Сэм: </><Speech>Наверное, да, но, думаю, запасов у меня достаточно. Сообщу, если что-то понадобится.</>"

#. Key:	FF3747BF4E464EF9C347BDA80C163CC8
msgctxt ",FF3747BF4E464EF9C347BDA80C163CC8"
