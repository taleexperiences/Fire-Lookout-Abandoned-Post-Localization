msgctxt ",BFEA3427416D3F0616D753B7C1CCC2F3"
msgid "<Sam>Sam: </><Speech>Alright.</>"
msgstr "<Sam>Сэм: </><Speech>Ладно.</>"

#. Key:	185572004D36CEEBCC21998ABFB26A75
msgctxt ",185572004D36CEEBCC21998ABFB26A75"
msgid "<Speech>Alright.</>"
msgstr "<Speech>Ладно.</>"

#. Key:	ACDE71964693B44B0153439AA1D21311
msgctxt ",ACDE71964693B44B0153439AA1D21311"
msgid "<Rick>Rick: </><Speech>Good. Make sure everything’s there, and if it’s not, call me.</>"
msgstr "<Rick>Рик: </><Speech>Хорошо. Убедись, что всё на месте, а если чего-то нет — звони мне.</>"

#. Key:	A717C3E24E7EE08B10638BB6ADB91756
