msgctxt ",AF2C111B48BF8CCCBD29B1B125017B79"
msgid "<Kailyn>Kailyn: </><Speech>Well a ranger kind of owed me a favor.</>"
msgstr "<Kailyn>Кейлин: </><Speech>Ну, один рейнджер был мне должен услугу.</>"

#. Key:	10BFE3E649775E34E4E889997D3EE2C3
