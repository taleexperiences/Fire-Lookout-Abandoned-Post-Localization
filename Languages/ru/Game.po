msgid "<Sam>Sam: </><Speech>Oh...hey, I'm doing fine, just finishing up with the packing, making sure I don't forget anything.</>"
msgstr "<Sam>Сэм: </><Speech>Ох... привет, у меня всё нормально, просто заканчиваю собираться и проверяю, чтобы ничего не забыть.</>"

#. Key:	CA2F656340BC2D22F8CD0FB4749F4D41
msgctxt ",CA2F656340BC2D22F8CD0FB4749F4D41"
msgid "<Speech>I'm doing fine</>"
msgstr "<Speech>У меня всё нормально</>"

#. Key:	17CA2418443A764CFE7F758D74818089
msgctxt ",17CA2418443A764CFE7F758D74818089"
msgid "<Simon>Simon: </><Speech>Hey! It's Simon, how you holding up?</>"
msgstr "<Simon>Саймон: </><Speech>Привет! Это Саймон, как ты держишься?</>"

#. Key:	9BD9393941FFE97041F40FA6630D1F61
msgctxt ",9BD9393941FFE97041F40FA6630D1F61"
msgid "<Sam>Sam: </><Speech>Okay, got it!</>"
msgstr "<Sam>Сэм: </><Speech>Ладно, понял!</>"

#. Key:	BCEKailynD2D4D99A0DD77C89F97C45D81E3
msgctxt ",BCEKailynD2D4D99A0DD77C89F97C45D81E3"
msgid "<Speech>Okay</>"
msgstr "<Speech>Ладно</>"

#. Key:	EE0D4B944B1732FDBFEC1F9DF6554DB9
msgctxt ",EE0D4B944B1732FDBFEC1F9DF6554DB9"
msgid "<Rick>Rick: </><Speech>That's great to hear, you should get some rest. Tomorrow will be your first day. I'll call you at around 6 am, so make sure to be up by then.</>"
msgstr "<Rick>Рик: </><Speech>Рад это слышать, тебе стоит отдохнуть. Завтра будет твой первый день. Я позвоню примерно в шесть утра, так что проснись к тому времени.</>"

#. Key:	69EC6CC949E0F344CBDFB79DE8F8B3E1
msgctxt ",69EC6CC949E0F344CBDFB79DE8F8B3E1"
msgid "<Sam>Sam: </><Speech>Sure, just say the word and I'll teach you what I know</>"
msgstr "<Sam>Сэм: </><Speech>Конечно, только скажи, и я научу тебя всему, что знаю</>"

#. Key:	6E93A0664ACB012E6AFD698E46460CBD
msgctxt ",6E93A0664ACB012E6AFD698E46460CBD"
msgid "<Speech>Sure, just say the word</>"
msgstr "<Speech>Конечно, только скажи</>"

#. Key:	179DKailyn634E82EE91ADEBA2BAE40058BF
msgctxt ",179DKailyn634E82EE91ADEBA2BAE40058BF"
msgid "<Kailyn>Kailyn: </><Speech>But you know, you should teach me someday. You're actually really good</>"
msgstr "<Kailyn>Кейлин: </><Speech>Но знаешь, когда-нибудь ты тоже должен меня научить. У тебя правда хорошо получается</>"

#. Key:	510697324D1B64AKailynE7C58A7082B6506
