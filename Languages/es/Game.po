msgid "<Kailyn>Kailyn: </><Speech>But you know, you should teach me someday. You're actually really good</>"
msgstr "<Kailyn>Kailyn: </><Speech>Pero ya sabes, algún día deberías enseñarme. En realidad eres muy bueno</>"

#. Key:	510697324D1B64AKailynE7C58A7082B6506
