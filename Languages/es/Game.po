msgctxt ",6056A9594AB19863B82233BDC28E11F7"
msgid "<Sam>Sam: </><Speech>Sure seems that way. Not that I’m complaining.</>"
msgstr "<Sam>Sam: </><Speech>Eso parece. No es que me queje.</>"

#. Key:	646C66784AB591DF587BC291B4D6571A
