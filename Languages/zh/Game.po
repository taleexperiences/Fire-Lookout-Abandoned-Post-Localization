msgctxt ",7B922D3B4ADBD8EAA62F02975F23A5D7"
msgid "<Hiker>Hiker: </><Speech>Yeah yeah, don't worry about it. But can I get some lights on in here? It's dark as hell</>"
msgstr "<Hiker>徒步者: </><Speech>好好，别担心。但我能不能把这里的灯打开？这里黑得要命。</>"

#. Key:	7A17705E417B255F69EB6FB5227E171F
msgctxt ",7A17705E417B255F69EB6FB5227E171F"
msgid "<Sam>Sam: </><Speech>Okay...</>"
