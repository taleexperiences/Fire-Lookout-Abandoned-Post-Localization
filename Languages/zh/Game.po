msgid "<Hiker>Hiker: </><Speech>Alright... Another fork in the road... Where am I going?</>"
msgstr "<Hiker>徒步者: </><Speech>好吧……又一个岔路口……往前，还是往左？我该怎么办？</>"

#. Key:	437BA9F246FE1EB0064B6C855541F33A
msgctxt ",437BA9F246FE1EB0064B6C855541F33A"
msgid "<Sam>Sam: </><Speech>Then you should head to... the left!</>"
msgstr "<Sam>Sam: </><Speech>那你应该往……左边！</>"

