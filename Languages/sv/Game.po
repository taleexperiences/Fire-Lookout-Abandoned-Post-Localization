msgctxt ",54C5064846D926B2DF4C33B991DEE7FD"
msgid "<Sam>Sam: </><Speech>Uh yeah you're right, why are we even arguing about this?</>"
msgstr "<Sam>Sam: </><Speech>Öh, ja, du har rätt. Varför bråkar vi ens om det här?</>"

#. Key:	F4ACE12848B1048A138E20BB208440E7
msgctxt ",F4ACE12848B1048A138E20BB208440E7"
msgid "<Speech>Yeah you're right</>"
msgstr "<Speech>Ja, du har rätt</>"

#. Key:	F3BDB4F84E8E199023474F8E3412F38A
msgctxt ",F3BDB4F84E8E199023474F8E3412F38A"
msgid "<Sam>Sam: </><Speech>It does kind of matter, you can't just claim that one movie is better than the other, then when I prove you wrong you just try to change the subject.</>"
msgstr "<Sam>Sam: </><Speech>Det spelar faktiskt roll. Du kan inte bara påstå att en film är bättre än den andra, och sen när jag bevisar att du har fel försöker du bara byta ämne.</>"

#. Key:	AAEB9BCD4167064C1A2ADFB8B227917D
msgctxt ",AAEB9BCD4167064C1A2ADFB8B227917D"
msgid "<Speech>It does kind of matter</>"
msgstr "<Speech>Det spelar faktiskt roll</>"

#. Key:	152679E648E545BBAFEDA0A67090E671
