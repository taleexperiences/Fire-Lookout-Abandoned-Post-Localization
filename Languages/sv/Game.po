msgid "<Sam>Sam: </><Speech>Man, I wish Rick was here to back me up on this one.</>"
msgstr "<Sam>Sam: </><Speech>Man, jag önskar att Rick var här och backade upp mig i den här.</>"

#. Key:	8B73A17549975330B799A9A9F9D39E07
