msgctxt ",9BD9393941FFE97041F40FA6630D1F61"
msgid "<Sam>Sam: </><Speech>Okay, got it!</>"
msgstr "<Sam>Sam: </><Speech>Okej, uppfattat!</>"

#. Key:	BCEKailynD2D4D99A0DD77C89F97C45D81E3
msgctxt ",BCEKailynD2D4D99A0DD77C89F97C45D81E3"
msgid "<Speech>Okay</>"
msgstr "<Speech>Okej</>"

#. Key:	EE0D4B944B1732FDBFEC1F9DF6554DB9
msgctxt ",EE0D4B944B1732FDBFEC1F9DF6554DB9"
msgid "<Rick>Rick: </><Speech>That's great to hear, you should get some rest. Tomorrow will be your first day. I'll call you at around 6 am, so make sure to be up by then.</>"
msgstr "<Rick>Rick: </><Speech>Skönt att höra, du borde vila lite. I morgon är din första dag. Jag ringer dig runt klockan 6, så se till att vara uppe då.</>"

#. Key:	69EC6CC949E0F344CBDFB79DE8F8B3E1
msgctxt ",69EC6CC949E0F344CBDFB79DE8F8B3E1"
msgid "<Sam>Sam: </><Speech>Sure, just say the word and I'll teach you what I know</>"
msgstr "<Sam>Sam: </><Speech>Visst, säg bara till så lär jag dig det jag kan</>"

#. Key:	6E93A0664ACB012E6AFD698E46460CBD
msgctxt ",6E93A0664ACB012E6AFD698E46460CBD"
msgid "<Speech>Sure, just say the word</>"
msgstr "<Speech>Visst, säg bara till</>"

#. Key:	179DKailyn634E82EE91ADEBA2BAE40058BF
msgctxt ",179DKailyn634E82EE91ADEBA2BAE40058BF"
msgid "<Kailyn>Kailyn: </><Speech>But you know, you should teach me someday. You're actually really good</>"
msgstr "<Kailyn>Kailyn: </><Speech>Men du vet, du borde lära mig någon gång. Du är faktiskt riktigt bra</>"

#. Key:	510697324D1B64AKailynE7C58A7082B6506
msgctxt ",510697324D1B64AKailynE7C58A7082B6506"
msgid "<Sam>Sam: </><Speech>No I'm fine, Goodnight!</>"
msgstr "<Sam>Sam: </><Speech>Nej, det är lugnt. Godnatt!</>"

#. Key:	5C182F114B7FD3D5B1B18ABA91AA89DB
msgctxt ",5C182F114B7FD3D5B1B18ABA91AA89DB"
msgid "<Speech>I'm fine, goodnight!</>"
msgstr "<Speech>Det är lugnt, godnatt!</>"

#. Key:	35D917B648948CF57BAEE281F2E5585E
msgctxt ",35D917B648948CF57BAEE281F2E5585E"
msgid "<Sam>Sam: </><Speech>Well actually there is one thing</>"
msgstr "<Sam>Sam: </><Speech>Jo, egentligen finns det en sak</>"

#. Key:	DAD91AEA4B7D8DD8802BFFAAA5EA0A89
msgctxt ",DAD91AEA4B7D8DD8802BFFAAA5EA0A89"
msgid "<Speech>Well actually there is one thing</>"
msgstr "<Speech>Jo, egentligen finns det en sak</>"

#. Key:	75934D1B4D422F3EB1DFFE81467E7879
msgctxt ",75934D1B4D422F3EB1DFFE81467E7879"
msgid "<Kailyn>Kailyn: </><Speech>Well not tonight, cause it's getting late and I'm getting real tired. So I think I'm gonna go to bed, unless there is anything else you are wondering about?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Inte i kväll, för det börjar bli sent och jag är riktigt trött. Så jag tror jag ska gå och lägga mig, om det inte är något annat du undrar över?</>"

#. Key:	58A13C4B4F6C0656AECD728864DCEA3F
msgctxt ",58A13C4B4F6C0656AECD728864DCEA3F"
msgid "<Kailyn>Kailyn: </><Speech>Goodnight! Rookie</>"
msgstr "<Kailyn>Kailyn: </><Speech>Godnatt! Nykomling</>"

#. Key:	598AA84441D03181092C6FACF928C247
msgctxt ",598AA84441D03181092C6FACF928C247"
msgid "<Sam>Sam: </><Speech>Well...it's not like it's terrible, but I'm just you know...thinking about other options</>"
msgstr "<Sam>Sam: </><Speech>Tja... det är inte som att det är hemskt, men jag funderar bara på... andra alternativ</>"

#. Key:	52020BB74409DF988D640E828ED03BA8
msgctxt ",52020BB74409DF988D640E828ED03BA8"
msgid "<Speech>It's not terrible, just thinking about other options</>"
msgstr "<Speech>Det är inte hemskt, jag funderar bara på andra alternativ</>"

#. Key:	05B0636C44455DD5CC4CF6B74208CB17
msgctxt ",05B0636C44455DD5CC4CF6B74208CB17"
msgid "<Kailyn>Kailyn: </><Speech>Two weeks in and already picky about the food, are we?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Två veckor in och redan kräsen med maten, eller?</>"

#. Key:	646F30734AA5760A84D2C9B9F79799BB
msgctxt ",646F30734AA5760A84D2C9B9F79799BB"
msgid "<Sam>Sam: </><Speech>Fishing?</>"
msgstr "<Sam>Sam: </><Speech>Fiska?</>"

#. Key:	EA0F2782499A8017A2A5B58FD1956ABE
msgctxt ",EA0F2782499A8017A2A5B58FD1956ABE"
msgid "<Speech>Fishing?</>"
msgstr "<Speech>Fiska?</>"

#. Key:	4AD3BA264F84AEE8D64357BD70B5EC72
msgctxt ",4AD3BA264F84AEE8D64357BD70B5EC72"
msgid "<Kailyn>Kailyn: </><Speech>Mmm.... you could always go fishing</>"
msgstr "<Kailyn>Kailyn: </><Speech>Mmm... du kan ju alltid fiska</>"

#. Key:	744B2B3C4107BEAE3C53CEB57C7E3D08
msgctxt ",744B2B3C4107BEAE3C53CEB57C7E3D08"
msgid "<Sam>Sam: </><Speech>That sounds interesting, I might have to check that out.</>"
msgstr "<Sam>Sam: </><Speech>Det låter intressant, jag kanske måste kolla upp det.</>"

#. Key:	60D891684562D40BCCF289A7FAA83429
msgctxt ",60D891684562D40BCCF289A7FAA83429"
msgid "<Speech>That sounds interesting</>"
msgstr "<Speech>Det låter intressant</>"

#. Key:	722AD2F44B367F2476680FB521EA07EA
msgctxt ",722AD2F44B367F2476680FB521EA07EA"
msgid "<Kailyn>Kailyn: </><Speech>Yeah, down by the lake there is a little shed with a fishing rod and everything you need to fish really</>"
msgstr "<Kailyn>Kailyn: </><Speech>Ja, nere vid sjön finns ett litet skjul med ett fiskespö och egentligen allt du behöver för att fiska</>"

#. Key:	2B516C0B4E644E6C3A7052B83C0A3C2E
msgctxt ",2B516C0B4E644E6C3A7052B83C0A3C2E"
msgid "<Sam>Sam: </><Speech>That sounds interesting, I might have to check that out.</>"
msgstr "<Sam>Sam: </><Speech>Det låter intressant, jag kanske måste kolla upp det.</>"

#. Key:	6A39619C48974EA1B2145D8BF4FD9585
msgctxt ",6A39619C48974EA1B2145D8BF4FD9585"
msgid "<Speech>That sounds interesting</>"
msgstr "<Speech>Det låter intressant</>"

#. Key:	E485356145AA69046DC8CCBFEF35E7EA
msgctxt ",E485356145AA69046DC8CCBFEF35E7EA"
msgid "<Kailyn>Kailyn: </><Speech>No, it's not locked. It's provided by the park for people to use</>"
msgstr "<Kailyn>Kailyn: </><Speech>Nej, det är inte låst. Parken tillhandahåller det så folk kan använda det</>"

#. Key:	D15595FC4ECF3EB9A2EF88BA14487098
msgctxt ",D15595FC4ECF3EB9A2EF88BA14487098"
msgid "<Sam>Sam: </><Speech>No I'm fine, goodnight!</>"
msgstr "<Sam>Sam: </><Speech>Nej, det är lugnt, godnatt!</>"

#. Key:	CCD45BA94F9189F51D02DFB50E027341
msgctxt ",CCD45BA94F9189F51D02DFB50E027341"
msgid "<Speech>I'm fine, goodnight!</>"
msgstr "<Speech>Det är lugnt, godnatt!</>"

#. Key:	4B4712EF4A8EECAB77037A8A354EA10D
msgctxt ",4B4712EF4A8EECAB77037A8A354EA10D"
msgid "<Kailyn>Kailyn: </><Speech>Well I'm gonna go to bed unless there is anything else you are wondering about.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Jag går och lägger mig om det inte är något annat du undrar över.</>"

#. Key:	F337E4594ACB85655207F48E32D4CE65
msgctxt ",F337E4594ACB85655207F48E32D4CE65"
msgid "<Sam>Sam: </><Speech>But...he didn't come back?</>"
msgstr "<Sam>Sam: </><Speech>Men... han kom inte tillbaka?</>"

#. Key:	8C2FF7DC4A7A14629FB021884586C04A
msgctxt ",8C2FF7DC4A7A14629FB021884586C04A"
msgid "<Speech>He didn't come back?</>"
msgstr "<Speech>Han kom inte tillbaka?</>"

#. Key:	45B2D2F54DD19F81404290B5E697C98E
msgctxt ",45B2D2F54DD19F81404290B5E697C98E"
msgid "<Kailyn>Kailyn: </><Speech>In your tower? It was this older fella and let's say he wasn't the most productive. He used to just sit and talk with Rick all day, I think Rick liked him quite a lot. So of course he didn't get any work put on him.</>"
msgstr "<Kailyn>Kailyn: </><Speech>I ditt torn? Det var en äldre kille och låt oss säga att han inte var den mest produktiva. Han brukade bara sitta och prata med Rick hela dagarna, jag tror Rick gillade honom rätt mycket. Så såklart fick han inget jobb lagt på sig.</>"

#. Key:	FA674F4C49729C23A8DDC1A311E5E172
msgctxt ",FA674F4C49729C23A8DDC1A311E5E172"
msgid "<Sam>Sam: </><Speech>I understand, so I took his place?</>"
msgstr "<Sam>Sam: </><Speech>Jag förstår, så jag tog hans plats?</>"

#. Key:	CDF189E34E9372D9168CFD813AEFBF00
msgctxt ",CDF189E34E9372D9168CFD813AEFBF00"
msgid "<Speech>I took his place?</>"
msgstr "<Speech>Jag tog hans plats?</>"

#. Key:	382A24A64B3CD99F9789CC8DB3DD7F7F
msgctxt ",382A24A64B3CD99F9789CC8DB3DD7F7F"
msgid "<Kailyn>Kailyn: </><Speech>I bet he wanted to, but last year a fire broke out just west of your tower and guess who slept right through it. And someone had to take the blame so even if I know Rick would have wanted to keep him he had to let him go. But I am honestly relieved.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Jag tror säkert att han ville, men förra året bröt en brand ut strax väster om ditt torn och gissa vem som sov igenom alltihop. Någon var tvungen att ta skulden, så även om jag vet att Rick ville behålla honom fick han släppa honom. Men ärligt talat är jag lättad.</>"

#. Key:	AD7019EC463B88D8881750BEF7DFAA60
msgctxt ",AD7019EC463B88D8881750BEF7DFAA60"
msgid "<Sam>Sam: </><Speech>That early?</>"
msgstr "<Sam>Sam: </><Speech>Så tidigt?</>"

#. Key:	22E7A00048D763FKailynF409DB1AED6180D
msgctxt ",22E7A00048D763FKailynF409DB1AED6180D"
msgid "<Speech>That early?</>"
msgstr "<Speech>Så tidigt?</>"

#. Key:	4C2D2DDE4B40154689E634B35244F79A
msgctxt ",4C2D2DDE4B40154689E634B35244F79A"
msgid "<Rick>Rick: </><Speech>Well that's part of the job, better get used to it. Get some rest now, Tomorrow will be your first day. I'll call you at around 6 am, so make sure to be up by then.</>"
msgstr "<Rick>Rick: </><Speech>Tja, det är en del av jobbet, lika bra att vänja sig. Vila lite nu. I morgon är din första dag. Jag ringer dig runt klockan 6, så se till att vara uppe då.</>"

#. Key:	1A26AF8440B46050543858A4E247DEB9
msgctxt ",1A26AF8440B46050543858A4E247DEB9"
msgid "<Sam>Sam: </><Speech>Well wouldn't it be more convenient if I was in Thorncliff?</>"
msgstr "<Sam>Sam: </><Speech>Skulle det inte vara smidigare om jag var i Thorncliff?</>"

#. Key:	1A7904114D1B2F1F57E63E9FD8E155DB
msgctxt ",1A7904114D1B2F1F57E63E9FD8E155DB"
msgid "<Speech>Wouldn't it be more convenient if I was in Thorncliff?</>"
msgstr "<Speech>Skulle det inte vara smidigare om jag var i Thorncliff?</>"

#. Key:	6284025E41F76A34AF62DCA4FFE98309
msgctxt ",6284025E41F76A34AF62DCA4FFE98309"
msgid "<Kailyn>Kailyn: </><Speech>Yeah, well kind of. What you were really hired for was because a technician is required due to our own radio tower we have here that could require fixing. But for some reason Rick didn't want to put you at Thorncliff so you got that lookout.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Ja, typ. Det du egentligen anställdes för var att det behövs en tekniker på grund av vårt eget radiotorn här, som kan behöva repareras. Men av någon anledning ville Rick inte placera dig i Thorncliff, så du fick det där utkikstornet.</>"

#. Key:	DBF599714463D5A966913E996283D0A9
msgctxt ",DBF599714463D5A966913E996283D0A9"
msgid "<Sam>Sam: </><Speech>Ah I understand, Rick is really a stubborn one isn't he?</>"
msgstr "<Sam>Sam: </><Speech>Ah, jag förstår. Rick är verkligen envis, eller hur?</>"

#. Key:	584193BC4CDE2C7CC93D81923E33928D
msgctxt ",584193BC4CDE2C7CC93D81923E33928D"
msgid "<Speech>Rick is really a stubborn one isn't he?</>"
msgstr "<Speech>Rick är verkligen envis, eller hur?</>"

#. Key:	5B1BE38543880D9C1D869E8F556C3F1F
msgctxt ",5B1BE38543880D9C1D869E8F556C3F1F"
msgid "<Kailyn>Kailyn: </><Speech>Oh 100% but you know, Rick's park, Rick's rules.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Åh, hundra procent. Men du vet, Ricks park, Ricks regler.</>"

#. Key:	C1E5B7Kailyn41DB89890A39D3BB7415D24E
msgctxt ",C1E5B7Kailyn41DB89890A39D3BB7415D24E"
msgid "<Sam>Sam: </><Speech>What made you hate him so much?</>"
msgstr "<Sam>Sam: </><Speech>Vad fick dig att hata honom så mycket?</>"

#. Key:	DE1978A24B14490B310A96A00E23408A
msgctxt ",DE1978A24B14490B310A96A00E23408A"
msgid "<Speech>What made you hate him so much?</>"
msgstr "<Speech>Vad fick dig att hata honom så mycket?</>"

#. Key:	E319E229406AFB96095547BC1A071504
msgctxt ",E319E229406AFB96095547BC1A071504"
msgid "<Kailyn>Kailyn: </><Speech>Yep, pain in my ass. But, hey! He's the boss</>"
msgstr "<Kailyn>Kailyn: </><Speech>Japp, en riktig plåga. Men hej, han är chefen</>"

#. Key:	8B97E4CD46DADE8C1E821199D328BC24
msgctxt ",8B97E4CD46DADE8C1E821199D328BC24"
msgid "<Sam>Sam: </><Speech>I get what you're saying. I honestly kind of feel like there is something off about him</>"
msgstr "<Sam>Sam: </><Speech>Jag fattar vad du menar. Ärligt talat känns det som att det är något skumt med honom</>"

#. Key:	9634F8024E1E3202A3359D9911C61510
msgctxt ",9634F8024E1E3202A3359D9911C61510"
msgid "<Speech>I get what you're saying.</>"
msgstr "<Speech>Jag fattar vad du menar.</>"

#. Key:	C570C7AF4284DB8901E915B5619377DD
msgctxt ",C570C7AF4284DB8901E915B5619377DD"
msgid "<Kailyn>Kailyn: </><Speech>I don't hate him, I just wish he could ease up sometimes. It's not like we are watching over a nuclear power plant here</>"
msgstr "<Kailyn>Kailyn: </><Speech>Jag hatar honom inte, jag önskar bara att han kunde slappna av ibland. Det är inte direkt som att vi vaktar ett kärnkraftverk här</>"

#. Key:	6AA5DD484FF4E1731AF6C9A6260593EE
msgctxt ",6AA5DD484FF4E1731AF6C9A6260593EE"
msgid "<Sam>Sam: </><Speech>It just feels like he is not telling us everything, like a week back when he made me go put out a fire and I reported back to him that the campers were gone but all their camping equipment was still there. He just got quiet and then suddenly he had gotten a call from the hikers that they were gonna come back for it. I don't know it just seems unbelievable to me, don't you think?</>"
msgstr "<Sam>Sam: </><Speech>Det känns bara som att han inte berättar allt för oss. Som för en vecka sedan när han fick mig att släcka en eld, och jag rapporterade tillbaka att camparna var borta men att all deras utrustning fortfarande låg kvar. Han blev bara tyst, och plötsligt hade han fått ett samtal från vandrarna om att de skulle komma tillbaka efter grejerna. Jag vet inte, det känns bara otroligt för mig, tycker du inte?</>"

#. Key:	0C98C88C4FA2014E0115E7B6D6EC6422
msgctxt ",0C98C88C4FA2014E0115E7B6D6EC6422"
msgid "<Speech>I feel like he's not telling us everything</>"
msgstr "<Speech>Det känns som att han inte berättar allt för oss</>"

#. Key:	C98DCF384034B80F931A869DC727670C
msgctxt ",C98DCF384034B80F931A869DC727670C"
msgid "<Kailyn>Kailyn: </><Speech>Off about him? What do you mean?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Skumt med honom? Vad menar du?</>"

#. Key:	42D4AKailynE4E053B1C7B12C0A9DBD3CB17
msgctxt ",42D4AKailynE4E053B1C7B12C0A9DBD3CB17"
msgid "<Sam>Sam: </><Speech>Maybe, I just can't shake the feeling. Something feels off about him.</>"
msgstr "<Sam>Sam: </><Speech>Kanske, jag kan bara inte skaka av mig känslan. Något känns fel med honom.</>"

#. Key:	5808D7D24FE20BA9BEC03C98780C104F
msgctxt ",5808D7D24FE20BA9BEC03C98780C104F"
msgid "<Speech>Yeah maybe</>"
msgstr "<Speech>Ja, kanske</>"

#. Key:	DDEED1F44A5C301D95D42F887CD9E1AE
msgctxt ",DDEED1F44A5C301D95D42F887CD9E1AE"
msgid "<Kailyn>Kailyn: </><Speech>That is a bit strange, but don't you think you are overthinking it a little? I mean Rick knows a lot of hikers that travel within the park, so I don't think it's impossible that he probably knew the hikers.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Det är lite konstigt, men tror du inte att du övertänker det lite? Jag menar, Rick känner många vandrare som rör sig i parken, så jag tycker inte det är omöjligt att han kanske kände vandrarna.</>"

#. Key:	3167E38342D15CEDC97A51B257663DFD
msgctxt ",3167E38342D15CEDC97A51B257663DFD"
msgid "<Sam>Sam: </><Speech>Well you know, like...actually just forget it.</>"
msgstr "<Sam>Sam: </><Speech>Tja, du vet, alltså... äh, glöm det bara.</>"

#. Key:	3A7F0C7A40858B4A505845B1BA1F0C3B
msgctxt ",3A7F0C7A40858B4A505845B1BA1F0C3B"
msgid "<Speech>Well you know...</>"
msgstr "<Speech>Tja, du vet...</>"

#. Key:	AAF57A6E43F3C4AEBAE3D393991AFB03
msgctxt ",AAF57A6E43F3C4AEBAE3D393991AFB03"
msgid "<Kailyn>Kailyn: </><Speech>I've worked with him for quite a while and sure he is a bit strange but what are you trying to say, he knows something he isn't telling us?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Jag har jobbat med honom rätt länge och visst, han är lite märklig, men vad försöker du säga? Att han vet något han inte berättar för oss?</>"

#. Key:	53B3A0A54246A7CBBDAD2EBD04201CC7
msgctxt ",53B3A0A54246A7CBBDAD2EBD04201CC7"
msgid "<Sam>Sam: </><Speech>Yeah yeah, sure thing</>"
msgstr "<Sam>Sam: </><Speech>Ja ja, absolut</>"

#. Key:	1FDD8E1F493Kailyn50608B47288E07C03EC
msgctxt ",1FDD8E1F493Kailyn50608B47288E07C03EC"
msgid "<Speech>Yeah yeah, sure thing</>"
msgstr "<Speech>Ja ja, absolut</>"

#. Key:	E88856B34CBC99FD4FAC2F9809933876
msgctxt ",E88856B34CBC99FD4FAC2F9809933876"
msgid "<Kailyn>Kailyn: </><Speech>Oh kaaay, but if anything else comes to mind that makes you wonder, don't be afraid to tell me.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Okeeej, men om du kommer på något annat som får dig att undra, var inte rädd för att säga det till mig.</>"

#. Key:	E8DEF99142E1CE249B8E88A73DD30E60
msgctxt ",E8DEF99142E1CE249B8E88A73DD30E60"
msgid "<Sam>Sam: </><Speech>No I'm fine, goodnight!</>"
msgstr "<Sam>Sam: </><Speech>Nej, det är lugnt, godnatt!</>"

#. Key:	273AAD124780AA36A59BDB927B92CF61
msgctxt ",273AAD124780AA36A59BDB927B92CF61"
msgid "<Speech>I'm fine, goodnight!</>"
msgstr "<Speech>Det är lugnt, godnatt!</>"

#. Key:	D4D99D2443E9563BCB52A890C4DD7B4E
msgctxt ",D4D99D2443E9563BCB52A890C4DD7B4E"
msgid "<Sam>Sam: </><Speech>So you're telling me.. You think the Titanic is better than The Matrix?</>"
msgstr "<Sam>Sam: </><Speech>Så du säger alltså... att Titanic är bättre än The Matrix?</>"

#. Key:	EKailynD08184356CFA8CC157B963CC33EBF
msgctxt ",EKailynD08184356CFA8CC157B963CC33EBF"
msgid "<Speech>So you're telling me</>"
msgstr "<Speech>Så du säger alltså</>"

#. Key:	8E0F2CBF42D5700ED771DA9AE2DB1564
msgctxt ",8E0F2CBF42D5700ED771DA9AE2DB1564"
msgid "<Rick>Rick: </><Speech>Alright, see you in the morning.</>"
msgstr "<Rick>Rick: </><Speech>Okej, vi hörs i morgon bitti.</>"

#. Key:	278648104C268FE86E2E39932D42ADB7
msgctxt ",278648104C268FE86E2E39932D42ADB7"
msgid "<Sam>Sam: </><Speech>Sure, but 3 hours?!? I think I fell asleep half way through that movie.</>"
msgstr "<Sam>Sam: </><Speech>Visst, men 3 timmar?!? Jag tror jag somnade halvvägs genom den filmen.</>"

#. Key:	762208A24B9CKailynE86B475F8F1A3F9CA7
msgctxt ",762208A24B9CKailynE86B475F8F1A3F9CA7"
msgid "<Speech>Sure, but 3 hours!?</>"
msgstr "<Speech>Visst, men 3 timmar!?</>"

#. Key:	979D25E4435A596541D4DFBB1669E3DA
msgctxt ",979D25E4435A596541D4DFBB1669E3DA"
msgid "<Kailyn>Kailyn: </><Speech>Uh yeah? Do you know how sad it was when Jack died?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Öh, ja? Vet du hur sorgligt det var när Jack dog?</>"

#. Key:	35EF0D3D4A1F04983974F0996B1B0363
msgctxt ",35EF0D3D4A1F04983974F0996B1B0363"
msgid "<Sam>Sam: </><Speech>Uh.. Well technically no, but I know that what happens... Is not better than the Matrix</>"
msgstr "<Sam>Sam: </><Speech>Öh... tekniskt sett nej, men jag vet att det som händer... inte är bättre än The Matrix</>"

#. Key:	2C13866B4B161DE79670BDB509FBE307
