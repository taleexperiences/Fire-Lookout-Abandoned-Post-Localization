#. Key:	925F1AF544B5A5F8A4AC0099B7E96285
msgctxt ",925F1AF544B5A5F8A4AC0099B7E96285"
msgid "<Rick>Rick: </><Speech>Clearwater, answer the radio! You got a lot to do today.</>"
msgstr "<Rick>Rick: </><Speech>Clearwater, svara på radion! Du har mycket att göra i dag.</>"

#. Key:	CA1025FF4758084715CC8DA0770501F0
msgctxt ",CA1025FF4758084715CC8DA0770501F0"
msgid "<Sam>Sam: </><Speech>Yeah...having someone to talk to out here definitely makes things better too</>"
msgstr "<Sam>Sam: </><Speech>Ja... att ha någon att prata med här ute gör definitivt saker bättre också</>"

#. Key:	B80C5A5541BC04416E142C87EEFE641D
msgctxt ",B80C5A5541BC04416E142C87EEFE641D"
msgid "<Speech>Having someone to talk to out here definitely makes things better too</>"
msgstr "<Speech>Att ha någon att prata med här ute gör definitivt saker bättre också</>"

#. Key:	21E8D255441C64E4314DB483F3CABF17
msgctxt ",21E8D255441C64E4314DB483F3CABF17"
msgid "<Kailyn>Kailyn: </><Speech>You think so? I won't deny that it comes with it's challenges but the experience I would say makes it worth it.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Tycker du? Jag förnekar inte att det kommer med sina utmaningar, men upplevelsen tycker jag gör det värt det.</>"

#. Key:	06717E904323219E670F7496FFD4A7FF
msgctxt ",06717E904323219E670F7496FFD4A7FF"
msgid "<Sam>Sam: </><Speech>Yeah right, because he makes things so much less lonely</>"
msgstr "<Sam>Sam: </><Speech>Ja, eller hur, för han gör saker så mycket mindre ensamma</>"

#. Key:	B84FB0AD4050B0344FF8F1B93172D842
msgctxt ",B84FB0AD4050B0344FF8F1B93172D842"
msgid "<Speech>Yeah right</>"
msgstr "<Speech>Ja, eller hur</>"

#. Key:	6F8097A3495C98F5BE35418AD0CA4564
msgctxt ",6F8097A3495C98F5BE35418AD0CA4564"
msgid "<Kailyn>Kailyn: </><Speech>What? You mean Rick?</>"
msgstr "<Kailyn>Kailyn: </><Speech>Vad? Menar du Rick?</>"

#. Key:	FFE5DEC04568D8E00ED7AFA29BEDA0E3
msgctxt ",FFE5DEC04568D8E00ED7AFA29BEDA0E3"
msgid "<Sam>Sam: </><Speech>Maybe next time I go get my supplies, I should swing by your place. Get to see each other in person y'know.</>"
msgstr "<Sam>Sam: </><Speech>Nästa gång jag hämtar mina förnödenheter kanske jag borde svänga förbi hos dig. Få se varandra på riktigt, du vet.</>"

#. Key:	467F7A9046658A0C32764D9BA4A925CB
msgctxt ",467F7A9046658A0C32764D9BA4A925CB"
msgid "<Speech>Maybe next time I go get my supplies...</>"
msgstr "<Speech>Nästa gång jag hämtar mina förnödenheter kanske...</>"

#. Key:	E4EFA68A45C99EFBFDDD4B9A49BD83FE
msgctxt ",E4EFA68A45C99EFBFDDD4B9A49BD83FE"
msgid "<Kailyn>Kailyn: </><Speech>No but seriously, I do also appreciate having someone \"normal\" out here to talk to. Last summer was...rough.</>"
msgstr "<Kailyn>Kailyn: </><Speech>Nej men seriöst, jag uppskattar också att ha någon \"normal\" här ute att prata med. Förra sommaren var... jobbig.</>"

#. Key:	D56CBED14B88C0259F6BD2AD0F4E4047
msgctxt ",D56CBED14B88C0259F6BD2AD0F4E4047"
msgid "<Sam>Sam: </><Speech>Can't I just go around Rick's way?</>"
msgstr "<Sam>Sam: </><Speech>Kan jag inte bara gå runt Ricks väg?</>"

