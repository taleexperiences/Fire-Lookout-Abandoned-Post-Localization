#. Key:	A8EB99EC4BC71390CD5CE5A6B07B1663
msgctxt ",A8EB99EC4BC71390CD5CE5A6B07B1663"
msgid "<Sam>Sam: </><Speech>Well that's great to hear...</>"
msgstr "<Sam>Sam: </><Speech>Tja, det var ju skönt att höra...</>"

