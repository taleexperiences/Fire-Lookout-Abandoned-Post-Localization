msgctxt ",D09012D845C340D1CC051B963A5F4F52"
msgid "<Sam>Sam: </><Speech>You always walk up on people like that?</>"
msgstr "<Sam>Sam: </><Speech>Brukar du alltid smyga på folk sådär?</>"

#. Key:	8B2EA7A040B9642C5F611ABBB397402C
msgctxt ",8B2EA7A040B9642C5F611ABBB397402C"
