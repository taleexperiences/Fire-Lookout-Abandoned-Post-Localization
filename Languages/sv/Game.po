#. Key:	90D345054391BD4F8EA1FFAAAF1642FB
msgctxt ",90D345054391BD4F8EA1FFAAAF1642FB"
msgid "<Hiker>Park Ranger: </><Speech>Scared you didn't I? But, what are you doing out here anyway? You lost or something?</>"
msgstr "<Hiker>Parkvakt: </><Speech>Jag skrämde dig, va? Men vad gör du här ute egentligen? Är du vilse eller något?</>"

#. Key:	C579ECF4445433900C1ABAAC6E5D98B0
msgctxt ",C579ECF4445433900C1ABAAC6E5D98B0"
msgid "<Sam>Sam: </><Speech>Yeah, that's right.</>"
msgstr "<Sam>Sam: </><Speech>Ja, det stämmer.</>"

#. Key:	6F00F9FD493B2A0106415499002E2E6E
msgctxt ",6F00F9FD493B2A0106415499002E2E6E"
msgid "<Speech>Yeah</>"
msgstr "<Speech>Ja</>"

